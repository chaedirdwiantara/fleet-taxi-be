{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthDto"
                }
              }
            }
          }
        },
        "summary": "Liveness check",
        "tags": [
          "health"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Admin login — sets the session cookie",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "session": []
          }
        ],
        "summary": "Destroy the session",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "session": []
          }
        ],
        "summary": "Current session user",
        "tags": [
          "auth"
        ]
      }
    },
    "/admin/fleet/{platform}/imports": {
      "post": {
        "operationId": "ImportController_upload",
        "parameters": [
          {
            "name": "platform",
            "required": true,
            "in": "path",
            "schema": {
              "enum": [
                "gojek",
                "grab"
              ],
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "month",
                  "year"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "month": {
                    "type": "integer",
                    "example": 7
                  },
                  "year": {
                    "type": "integer",
                    "example": 2026
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": ""
          }
        },
        "security": [
          {
            "session": []
          }
        ],
        "summary": "Upload a CSV/XLSX for a period — parsed asynchronously",
        "tags": [
          "admin-fleet-imports"
        ]
      },
      "get": {
        "operationId": "ImportController_list",
        "parameters": [
          {
            "name": "platform",
            "required": true,
            "in": "path",
            "schema": {
              "enum": [
                "gojek",
                "grab"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "session": []
          }
        ],
        "summary": "List import batches",
        "tags": [
          "admin-fleet-imports"
        ]
      }
    },
    "/admin/fleet/{platform}/imports/{id}": {
      "get": {
        "operationId": "ImportController_getById",
        "parameters": [
          {
            "name": "platform",
            "required": true,
            "in": "path",
            "schema": {
              "enum": [
                "gojek",
                "grab"
              ],
              "type": "string"
            }
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "session": []
          }
        ],
        "summary": "Import status/progress (also streamed via Socket.IO /rt)",
        "tags": [
          "admin-fleet-imports"
        ]
      },
      "delete": {
        "operationId": "ImportController_rollback",
        "parameters": [
          {
            "name": "platform",
            "required": true,
            "in": "path",
            "schema": {
              "enum": [
                "gojek",
                "grab"
              ],
              "type": "string"
            }
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "202": {
            "description": ""
          }
        },
        "security": [
          {
            "session": []
          }
        ],
        "summary": "Rollback a whole import batch (queued)",
        "tags": [
          "admin-fleet-imports"
        ]
      }
    }
  },
  "info": {
    "title": "fleet-taxi-dashboard-api",
    "description": "Fleet/deposit-reconciliation dashboard API. All money values are integer rupiah serialized as JSON numbers. Every response uses the standard envelope: `{ success: true, data, meta? }` on success, `{ success: false, error: { code, message, details? } }` on error.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sid"
      },
      "partner-api-key": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Partner API key (external /partner/v1 only)"
      }
    },
    "schemas": {
      "HealthDto": {
        "type": "object",
        "properties": {}
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@fleet-taxi.id"
          },
          "password": {
            "type": "string",
            "example": "********"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}
