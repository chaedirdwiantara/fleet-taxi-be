  "info": {
    "title": "fleet-taxi-dashboard-api",
    "description": "Fleet/deposit-reconciliation dashboard API. All money values are integer rupiah serialized as JSON numbers. Every response uses the standard envelope: `{ success: true, data, meta? }` on success, `{ success: false, error: { code, message, details? } }` on error.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sid"
      },
      "partner-api-key": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Partner API key (external /partner/v1 only)"
      }
    },
    "schemas": {
      "HealthDto": {
        "type": "object",
        "properties": {}
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@fleet-taxi.id"
          },
          "password": {
            "type": "string",
            "example": "********"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateExceptionDto": {
        "type": "object",
        "properties": {
          "vehiclePlate": {
            "type": "string",
            "example": "B1234XY"
          },
          "exceptionDate": {
            "type": "string",
            "example": "2026-07-10",
            "description": "YYYY-MM-DD"
          },
          "keterangan": {
            "type": "string",
            "example": "Perbaikan bengkel"
          },
          "isBebasSetoran": {
            "type": "boolean",
            "default": false,
            "description": "true = bebas setoran (reduces target days)"
          }
        },
        "required": [
          "vehiclePlate",
          "exceptionDate"
        ]
      }
    }
  }
}
