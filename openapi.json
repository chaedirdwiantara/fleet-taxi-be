            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "month",
                  "year"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "month": {
                    "type": "integer",
                    "example": 7
                  },
                  "year": {
                    "type": "integer",
                    "example": 2026
                  }
